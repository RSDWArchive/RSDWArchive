# Copy this file to user-config.py and set your values.
# Keep user-config.py out of git if it contains account-specific values.

family = "rsdwwikidev"
mylang = "en"

# Replace with your bot account username on dev wiki.
usernames = {
    "rsdwwikidev": {
        "en": "RSDWArchiveBot"
    }
}

# Use script path "/" for standard wiki root.
family_files = {
    "rsdwwikidev": "https://en_rsdwwiki.dev.weirdgloop.org"
}

# Optional quality-of-life flags
put_throttle = 1
minthrottle = 1
maxthrottle = 5
