        {
          "Key": "EDialogMessageType::AskTelemetryConsent",
          "Value": {
            "HeaderText": {
              "TableId": "/Game/UI/GenericDialog/ST_GenericDialog.ST_GenericDialog",
              "Key": "TelemetryHeader",
              "SourceString": "Player activity plugin",
              "LocalizedString": "Player activity plugin"
            },
            "BodyText": {
              "TableId": "/Game/UI/GenericDialog/ST_GenericDialog.ST_GenericDialog",
              "Key": "TelemetryBody",
              "SourceString": "With your consent, we would like to automatically collect information from this device via a new player activity plugin. This information allows our team to review how players use systems and play the game to better address issues, expand on old systems, or add new features. With both activity and player feedback we are able to make better decisions about the future of the game. If you choose, we can also use this information to offer a better online advertising experience.",
              "LocalizedString": "With your consent, we would like to automatically collect information from this device via a new player activity plugin. This information allows our team to review how players use systems and play the game to better address issues, expand on old systems, or add new features. With both activity and player feedback we are able to make better decisions about the future of the game. If you choose, we can also use this information to offer a better online advertising experience."
            },
            "LeftButtonText": {
              "TableId": "/Game/UI/GenericDialog/ST_GenericDialog.ST_GenericDialog",
              "Key": "TelemetryLeftButton",
              "SourceString": "Accept all and continue",
              "LocalizedString": "Accept all and continue"
            },
            "RightButtonText": {
              "TableId": "/Game/UI/GenericDialog/ST_GenericDialog.ST_GenericDialog",
              "Key": "TelemetryRightButton",
              "SourceString": "Modify settings",
              "LocalizedString": "Modify settings"
            }
          }
